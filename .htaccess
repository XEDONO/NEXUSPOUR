<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Do not rewrite rule for the backend API
    RewriteRule ^php_server/ - [L]

    # Do not rewrite if the request is for an existing file
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Do not rewrite if the request is for an existing directory
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Rewrite all other requests to index.html to let React Router handle them
    RewriteRule . /index.html [L]
</IfModule>

# Proper MIME types for assets
<FilesMatch "\.(js|mjs)$">
    Header set Content-Type "application/javascript"
</FilesMatch>

<FilesMatch "\.css$">
    Header set Content-Type "text/css"
</FilesMatch>

# Cache control for assets
<FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# HTML files - no cache
<FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>
